pipeline {
    agent any

    environment {
        BACKEND_IMAGE = 'devansh1709/shoplane-backend'
        PAYMENT_IMAGE = 'devansh1709/shoplane-payment-gateway'
        IMAGE_TAG = "${BUILD_NUMBER}"
    }

    stages {
        stage('Build Ecommerce Backend') {
            steps {
                dir('Ecommerce-backend') {
                    sh 'chmod +x mvnw'
                    sh './mvnw clean compile -B'
                }
            }
        }

        stage('Test Ecommerce Backend') {
            steps {
                dir('Ecommerce-backend') {
                    sh './mvnw test -B'
                }
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: 'Ecommerce-backend/target/surefire-reports/*.xml'
                }
            }
        }

        stage('Build Payment Gateway') {
            steps {
                dir('Payment-Gateway') {
                    sh 'chmod +x mvnw'
                    sh './mvnw clean compile -B'
                }
            }
        }

        stage('Test Payment Gateway') {
            steps {
                dir('Payment-Gateway') {
                    sh './mvnw test -B'
                }
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: 'Payment-Gateway/target/surefire-reports/*.xml'
                }
            }
        }

        stage('Package Services') {
            steps {
                dir('Ecommerce-backend') {
                    sh './mvnw package -DskipTests -B'
                }

                dir('Payment-Gateway') {
                    sh './mvnw package -DskipTests -B'
                }
            }
        }

        stage('Docker Build') {
            steps {
                sh 'docker build -t ${BACKEND_IMAGE}:${IMAGE_TAG} -t ${BACKEND_IMAGE}:latest ./Ecommerce-backend'
                sh 'docker build -t ${PAYMENT_IMAGE}:${IMAGE_TAG} -t ${PAYMENT_IMAGE}:latest ./Payment-Gateway'
            }
        }

        stage('Validate Docker Compose') {
            steps {
                withEnv([
                    'MYSQL_USER=jenkins',
                    'MYSQL_PASSWORD=jenkins',
                    'MYSQL_ROOT_PASSWORD=jenkins',
                    'RAZORPAY_KEY_ID=dummy',
                    'RAZORPAY_KEY_SECRET=dummy',
                    'JWT_SECRET=dummy',
                    'JWT_EXPIRATION_MS=86400000',
                    'MAIL_USERNAME=dummy@example.com',
                    'MAIL_APP_PASSWORD=dummy'
                ]) {
                    sh 'docker-compose config --quiet'
                }
            }
        }

        stage('Push Docker Images') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'dockerhub-credentials',
                        usernameVariable: 'DOCKERHUB_USERNAME',
                        passwordVariable: 'DOCKERHUB_TOKEN'
                    )
                ]) {
                    sh '''
                        echo "$DOCKERHUB_TOKEN" | docker login \
                          --username "$DOCKERHUB_USERNAME" \
                          --password-stdin

                        docker push ${BACKEND_IMAGE}:${IMAGE_TAG}
                        docker push ${BACKEND_IMAGE}:latest

                        docker push ${PAYMENT_IMAGE}:${IMAGE_TAG}
                        docker push ${PAYMENT_IMAGE}:latest
                    '''
                }
            }
        }
    }

    post {
        success {
            echo 'CI pipeline completed successfully and Docker images were pushed!'
        }

        failure {
            echo 'Pipeline failed. Check the failed stage logs.'
        }

        always {
            sh 'docker logout || true'
        }
    }
}